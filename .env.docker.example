# Edge Assistant Production Environment Configuration

# -- Global Security --
PROJECT_NAME="Edge Assistant"
VERSION="1.0.0"
SECRET_KEY="replace_at_runtime_with_secure_key"
ALGORITHM="HS256"

# -- Database (Internal name 'db' is used in docker-compose) --
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=edge_assistant
POSTGRES_PORT=5432

# -- Redis (Internal name 'redis' is used in docker-compose) --
REDIS_HOST=redis
REDIS_PORT=6379

# -- Vertex AI Credentials --
VERTEX_PROJECT_ID="your-project-id"
VERTEX_LOCATION="us-central1"
VERTEX_MODEL="gemini-2.0-flash"
# This file MUST exist in your ./backend folder
VERTEX_KEY_PATH="vertex-key.json"

# -- Data Directories --
# (Mapped to volumes in docker-compose)
AE_STUDIO_DATA_DIR="/app/ae_studio_data"
